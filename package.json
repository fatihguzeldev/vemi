{
  "name": "@fatihguzeldev/vemi",
  "version": "0.0.1",
  "type": "module",
  "description": "a tiny, type-safe content compiler.",
  "keywords": [
    "markdown",
    "compiler",
    "html",
    "parser",
    "ast",
    "typescript",
    "content",
    "markup"
  ],
  "homepage": "https://github.com/fatihguzeldev/vemi#readme",
  "bugs": {
    "url": "https://github.com/fatihguzeldev/vemi/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fatihguzeldev/vemi.git"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "license": "ISC",
  "author": {
    "name": "fatih guzel",
    "email": "hello@fatihguzel.dev",
    "url": "https://fatihguzel.dev"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "dev:site": "npm run dev --workspace=vemi-tour",
    "build:site": "npm run build --workspace=vemi-tour",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "prepublishOnly": "npm run build && npm run test:run",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "workspaces": [
    "site"
  ],
  "devDependencies": {
    "@commitlint/cli": "20.4.2",
    "@commitlint/config-conventional": "20.4.2",
    "@typescript-eslint/eslint-plugin": "8.56.0",
    "@typescript-eslint/parser": "8.56.0",
    "eslint": "10.0.1",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "prettier": "3.8.1",
    "tsc-alias": "1.8.16",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
